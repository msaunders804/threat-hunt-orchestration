# ═════════════════════════════════════════════════════════════════════════
#  Threat Hunt Orchestrator — configuration
#  All values have safe defaults; copy to .env and override as needed.
# ═════════════════════════════════════════════════════════════════════════

# ── Inference provider ──────────────────────────────────────────────────
# One of: anthropic (default), bedrock, ollama
INFERENCE_PROVIDER=anthropic

# Default / frontier model, interpreted per-provider.
#   anthropic -> e.g. claude-sonnet-4-6
#   ollama    -> e.g. llama3.1:8b
#   bedrock   -> uses BEDROCK_MODEL_ID below
DIRECT_MODEL=claude-sonnet-4-6

# Optional per-role overrides (blank = use DIRECT_MODEL). Roles:
#   router   = supervisor routing (cheap/SLM-friendly)
#   parse    = scan/log parsing
#   triage   = vuln + router-config analysis (frontier)
#   sigma    = Sigma rule authoring (frontier)
#   synthesis= final report (frontier)
# Example — run only routing on a local SLM while keeping frontier elsewhere:
#   ROUTER_MODEL=llama3.1:8b
# ROUTER_MODEL=
# PARSE_MODEL=
# TRIAGE_MODEL=
# SIGMA_MODEL=
# SYNTHESIS_MODEL=

# ── Anthropic direct (dev / local) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS GovCloud Bedrock (prod swap / air-gapped) ───────────────────────
# Set INFERENCE_PROVIDER=bedrock and supply AWS credentials to route all
# Claude calls through Bedrock instead of the direct Anthropic API.
# See config/README.md for the full swap procedure.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-gov-west-1
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20251114-v1:0

# ── Ollama (fully local SLMs) ───────────────────────────────────────────
# INFERENCE_PROVIDER=ollama
# DIRECT_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# ── Elasticsearch ───────────────────────────────────────────────────────
# ES_MODE: mock (local fixtures, default) | live
ES_MODE=mock
# ES_URL=http://localhost:9200
# Auth: prefer ES_API_KEY (the "encoded" value from _security/api_key);
# basic auth is offered for lab convenience.
# ES_API_KEY=
# ES_USERNAME=elastic
# ES_PASSWORD=
# ES_FLOW_INDEX=packetbeat-*,zeek-conn-*
# ES_EVENT_INDEX=logs-*,winlogbeat-*

# ── External threat intel (off in air-gapped deployments) ───────────────
EXTERNAL_TI_ENABLED=false
# VIRUSTOTAL_API_KEY=
# SHODAN_API_KEY=
# OTX_API_KEY=

# ── Obsidian shared vault (Donut task/knowledge-base workflow) ──────────
# Path to the shared Obsidian vault folder. Leave blank — the agent discovers
# and sets this on first use (chat: "configure your vault").
SHARED_FOLDER=

# ── Output ──────────────────────────────────────────────────────────────
# Where network-map notes and Sigma rules are written.
# VAULT_PATH=vault
# SIGMA_OUTPUT_PATH=vault/detections
