# ── Anthropic direct (dev / local) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Obsidian shared vault ─────────────────────────────────────────────────────
# Path to the shared Obsidian vault folder (set via chat: "configure your vault").
# Leave blank — the agent will discover and set this automatically on first use.
SHARED_FOLDER=

# ── AWS GovCloud Bedrock (prod swap) ─────────────────────────────────────────
# Set INFERENCE_PROVIDER=bedrock and supply AWS credentials to route all
# Claude calls through Bedrock instead of the direct Anthropic API.
# See config/README.md for the full swap procedure.
#
# INFERENCE_PROVIDER=bedrock
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-gov-west-1
# BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20251114-v1:0
