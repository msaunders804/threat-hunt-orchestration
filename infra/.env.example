# Elastic stack (home-lab test instance) — copy to infra/.env
# Pick a current 8.x release tag (https://www.docker.elastic.co/).
STACK_VERSION=8.17.3

# Passwords for the built-in users. Change these.
ELASTIC_PASSWORD=changeme-elastic
KIBANA_PASSWORD=changeme-kibana

# ES JVM heap. On a 32GB box, 4g is comfortable alongside Kibana + Ollama.
ES_HEAP=4g

# Host ports.
ES_PORT=9200
KIBANA_PORT=5601

# Basic license = free forever (this is the default; do not set to trial).
LICENSE=basic
